# Keenon Cloud API
# Environment variables override missing YAML connector_config fields.
# Prefix: INORBIT_KEENON_
INORBIT_KEENON_API_DOMAIN=https://es.robotkeenon.com
INORBIT_KEENON_CLIENT_ID=your-client-id
INORBIT_KEENON_CLIENT_SECRET=your-client-secret
INORBIT_KEENON_VERIFY_SSL=true
# INORBIT_KEENON_WEBHOOK_PORT=8080

# InOrbit
INORBIT_API_KEY=your-inorbit-api-key
# INORBIT_API_URL=http://localdev.com:3000/cloud_sdk_robot_config
